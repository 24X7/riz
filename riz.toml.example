[server]
port = 3000
host = "0.0.0.0"
stage = "$default"   # API GW v2 stage — surfaces as requestContext.stage

[cache]
default_ttl_secs = 0
max_size_mb = 128

[datadog]
enabled = false
statsd_host = "127.0.0.1:8125"
service = "riz"
env = "production"

[deploy]
# deploy_key = "changeme"   # prefer RIZ_DEPLOY_KEY env var
allowed_cidrs = []          # empty = allow all IPs

[aws]
region = "us-east-1"

# Function-centric config matches AWS Lambda + API Gateway v2.
# One [function.<name>] = one process pool, N routes.

[function.signin]
runtime = "bun"
handler = "signin.handler"            # AWS-style: file=signin.ts, export=handler
timeout_ms = 5000
integration_timeout_ms = 30000        # API GW v2 IntegrationTimeoutInMillis
concurrency = 2

[[function.signin.routes]]
path = "/auth/signin"
method = "POST"

[function.accounts]
runtime = "bun"
handler = "./lambdas/accounts/index.ts"   # Riz-native: explicit path also works
timeout_ms = 3000
cache_ttl_secs = 30
concurrency = 1
stage_variables = { backend = "https://accounts-api.internal" }

[[function.accounts.routes]]
path = "/accounts/{id}"               # AWS-style single-segment param
method = "GET"

[[function.accounts.routes]]
path = "/accounts/{proxy+}"           # AWS-style greedy proxy
method = "ANY"

# ── Brokered capabilities (WASM functions) ──────────────────────────────────
# A wasm guest reaches external resources only through the host broker: it
# names a grant, the daemon does the I/O under the grant's limits, and no
# credential ever crosses the sandbox. Resources are declared once; grants
# reference them per function.
#
# [resources.pg.main]
# dsn_env = "RIZ_PG_MAIN_DSN"          # credential lives in the HOST env only
# max_connections = 5
#
# [resources.http.stripe]
# base_url = "https://api.stripe.com"  # origin is pinned; guest supplies a path
# auth = { kind = "bearer", token_env = "STRIPE_SECRET_KEY" }
#
# [function.orders]
# runtime = "wasm"
# handler = "./orders/target/wasm32-wasip1/release/orders.wasm"
#
# [function.orders.capabilities.db]
# type = "pg"; resource = "pg.main"; mode = "read-write"; max_inflight = 4
#
# [function.orders.capabilities.payments]
# type = "http"; resource = "http.stripe"; methods = ["POST"]; rate_per_sec = 20
